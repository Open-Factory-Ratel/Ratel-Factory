{
  "name": "@ratel-factory/pi-extension",
  "version": "0.2.2",
  "description": "Ratel Factory — native Pi Coding Agent extension. Runs the Ratel orchestrator in-process (no HTTP service, no `ratel --serve`) and registers Pi commands, tools, lifecycle hooks, and a bundled skill so Pi users can run Ratel missions directly inside Pi.",
  "keywords": [
    "pi-package",
    "ratel",
    "ai-software-factory",
    "pi-extension"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "pi": {
    "extensions": ["./dist/index.js"],
    "skills": ["./skills"]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "skills/"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true})\" && tsc",
    "dev": "tsx src/index.ts",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@ratel-factory/core": "^0.2.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "typebox": "^1.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
