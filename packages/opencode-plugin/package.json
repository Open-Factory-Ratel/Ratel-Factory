{
  "name": "@ratel-factory/opencode",
  "version": "0.1.4",
  "description": "Ratel OpenCode Plugin — Factory adapter for OpenCode",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "commands/",
    "skills/"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc",
    "dev": "tsx src/plugin.ts",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.1.10",
    "@ratel-factory/core": "^0.1.2"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
