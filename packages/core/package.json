{
  "name": "@ratel-factory/core",
  "version": "0.1.2",
  "description": "Ratel AI Software Factory — Core Service",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./service": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core/*": {
      "import": "./dist/core/*.js",
      "types": "./dist/core/*.d.ts"
    },
    "./observatory/*": {
      "import": "./dist/observatory/*.js",
      "types": "./dist/observatory/*.d.ts"
    }
  },
  "bin": {
    "ratel": "dist/index.js"
  },
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc && node -e \"require('fs').cpSync('src/observatory/dashboard.html','dist/observatory/dashboard.html')\"",
    "dev": "tsx src/index.ts --serve",
    "start": "node dist/index.js --serve",
    "test": "echo 'No tests in @ratel-factory/core yet'"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.0",
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@sinclair/typebox": "^0.34.49",
    "pi-orch-extension": "^1.0.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
